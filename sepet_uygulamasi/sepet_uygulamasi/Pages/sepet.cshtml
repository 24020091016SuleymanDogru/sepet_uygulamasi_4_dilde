@page
@model sepet_uygulamasi.Pages.SepetModel
@{
    ViewData["Title"] = "Sepetim";
    decimal genelToplam = 0;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white p-4 rounded-top-4 d-flex justify-content-between align-items-center">
                    <h3 class="mb-0">🛍️ Alışveriş Sepetim</h3>
                    <span class="badge bg-light text-dark fs-6 rounded-pill px-3 py-2">
                        @(Model.AktifSepet?.SiparisDetaylari?.Count ?? 0) Çeşit Ürün
                    </span>
                </div>

                <div class="card-body p-4 p-md-5">
                    @if (Model.AktifSepet == null || Model.AktifSepet.SiparisDetaylari == null || Model.AktifSepet.SiparisDetaylari.Count == 0)
                    {
                        <div class="text-center py-5">
                            <h4 class="text-muted mb-4">Sepetin şu an bomboş görünüyor.</h4>
                            <a href="/" class="btn btn-outline-primary btn-lg rounded-pill px-5 shadow-sm">Alışverişe Başla</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col" class="text-muted border-0 pb-3">Ürün Detayı</th>
                                        <th scope="col" class="text-muted border-0 pb-3">Birim Fiyat</th>
                                        <th scope="col" class="text-muted border-0 pb-3 text-center">Miktar</th>
                                        <th scope="col" class="text-muted border-0 pb-3">Toplam</th>
                                        <th scope="col" class="text-muted border-0 pb-3 text-end">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody class="border-top-0">
                                    @foreach (var detay in Model.AktifSepet.SiparisDetaylari)
                                    {
                                        var satirToplami = detay.Adet * detay.Urun.Fiyat;
                                        genelToplam += satirToplami;

                                        <tr>
                                            <td class="fw-bold fs-5 py-3">@detay.Urun.UrunAdi</td>
                                            <td class="py-3">@detay.Urun.Fiyat.ToString("C2")</td>
                                            <td class="text-center py-3">
                                                <span class="badge bg-secondary bg-opacity-10 text-dark border border-secondary border-opacity-25 rounded-pill px-3 py-2 fs-6">
                                                    @detay.Adet
                                                </span>
                                            </td>
                                            <td class="fw-bold text-success py-3">@satirToplami.ToString("C2")</td>
                                            <td class="text-end py-3">
                                                <form method="post" asp-page-handler="UrunCikar" class="d-inline">
                                                    <input type="hidden" name="detayId" value="@detay.DetayID" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                        Sil
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <hr class="my-4 border-secondary opacity-25">

                        <div class="row align-items-center mt-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <form method="post" asp-page-handler="SepetiTemizle" class="d-inline">
                                    <input type="hidden" name="siparisId" value="@Model.AktifSepet.SiparisID" />
                                    <button type="submit" class="btn btn-link text-danger text-decoration-none fw-semibold p-0">
                                        🗑️ Sepeti Tamamen Temizle
                                    </button>
                                </form>
                            </div>
                            <div class="col-md-6 text-md-end">
                                <div class="d-flex flex-column align-items-md-end">
                                    <span class="text-muted mb-1">Ödenecek Tutar</span>
                                    <h2 class="fw-bold text-dark mb-4">@genelToplam.ToString("C2")</h2>

                                    <button class="btn btn-success btn-lg rounded-pill px-5 shadow fw-bold">
                                        Siparişi Tamamla 🚀
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>